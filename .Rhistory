# Load libraries
library(Seurat)
library(sctransform)
library(glmGamPoi)
library(cluster) # for silhouette function
library(tidyverse)
library(patchwork)
# set default ggplot theme
theme_set(theme_classic())
# Load the integrated data (batch corrected)
seurat_object <- readRDS("RObjects/DI.500.rds")
# Load the integrated data (batch corrected)
